# Copy to `.env` or `.env.local` in this folder (`web/`), then restart Vite.
# Only names prefixed with VITE_ are exposed to the browser.

# Laravel API base URL (no trailing slash required; it is stripped in code).
# Default in code if unset: http://127.0.0.1:8000/api/v1
VITE_API_BASE_URL=http://127.0.0.1:8000/api/v1

# Optional static bearer token (Passport / Sanctum). Login may override via localStorage.
# Leave empty for normal auth-only usage.
# VITE_API_ACCESS_TOKEN=

# Tenant id used by POS, Cashier, Menu, Inventory, Purchase flows. Default in code: 1
VITE_API_TENANT_ID=1

# WebSocket URL for realtime (orders, kitchen, payments, etc.). Empty disables env-based URL.
# Example: ws://127.0.0.1:6001  (adjust to your Reverb/Pusher/Soketi setup)
# VITE_REALTIME_WS_URL=

# Optional: overrides server `PAYMENT_DEFAULT_PROVIDER` for this browser build only.
# If unset, `POST /payment-transactions` is sent **without** `provider` and the API uses `PAYMENT_DEFAULT_PROVIDER` from `api/.env`.
# Must match a key under `config/payments.php` → `providers` (e.g. midtrans, xendit, manual).
# VITE_PAYMENT_DEFAULT_PROVIDER=xendit
# Optional: enable sandbox payment simulator for testing. Default: false
# VITE_ENABLE_SANDBOX_PAYMENT_SIMULATOR=true